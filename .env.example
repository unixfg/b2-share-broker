# b2-share-broker local development
#
# Copy this file to .env and fill in the values for your environment.
# The docker-compose.yaml setup runs against your external OIDC issuer
# (Keycloak or any OIDC provider) and an external B2 bucket.

# --- OIDC ---
# Point at your OIDC issuer. For a local Keycloak this might be
# http://localhost:8081/realms/yourrealm
OIDC_ISSUER_URL=https://keycloak.example.invalid/realms/yourrealm
OIDC_CLIENT_ID=b2-share-web
OIDC_CLIENT_SECRET=
OIDC_AUDIENCE=b2-share-web
OIDC_REQUIRED_ROLES=b2-share-user

# --- B2 / S3 ---
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_REGION=us-west-004
B2_BUCKET=
B2_PUBLIC_BASE_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- App ---
# The public URL that share links will use. For local docker-compose this is
# the traefik entrypoint on port 8080.
PUBLIC_BASE_URL=http://localhost:8080
# Comma-separated origins allowed CORS on /s/* redirects (e.g. Discord).
PUBLIC_SHARE_CORS_ALLOWED_ORIGINS=
# At least 32 bytes. Generate with: openssl rand -base64 32
SESSION_AUTH_KEY=
MAX_UPLOAD_BYTES=2147483648
SESSION_TTL_SECONDS=43200
FFMPEG_PATH=/usr/bin/ffmpeg
TRANSCODER_WORK_DIR=/work
TRANSCODER_POLL_SECONDS=5
STAGING_DIR=/staging

# --- Database ---
# Points at the postgres service in docker-compose. For external Postgres,
# replace with your own DSN.
DATABASE_URL=postgres://b2_share_broker:devpassword@postgres:5432/b2_share_broker?sslmode=disable
